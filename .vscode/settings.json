{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },
  "files.exclude": {
    "**/node_modules": true,
    "functions/node_modules": true,
    "functions/lib": true,
    "**/dist": true,
    "**/.expo": true,
    "**/.firebase": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "functions/node_modules": true,
    "functions/lib": true,
    "**/dist": true,
    "**/.git": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/node_modules/**": true,
    "functions/node_modules/**": true,
    "functions/lib/**": true,
    "**/dist/**": true,
    "**/.expo/**": true
  }
}
