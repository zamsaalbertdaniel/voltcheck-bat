# ═══════════════════════════════════════════
# VoltCheck — Environment Variables Template
# Copy this to .env.local and fill in real values
# NEVER commit .env.local to git!
# ═══════════════════════════════════════════

# ── Firebase Client SDK (Public — safe for client) ──
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Stripe (Public Key — safe for client) ──
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ── API Base URL (Cloud Functions region) ──
EXPO_PUBLIC_FUNCTIONS_REGION=europe-west1

# ═══════════════════════════════════════════
# SERVER-SIDE ONLY — Cloud Functions (.env)
# Set these via: firebase functions:config:set
# Or in Firebase Console → Functions → Environment
# ═══════════════════════════════════════════

# ── Stripe (Secret — NEVER expose to client) ──
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── VIN Providers (Secret — NEVER expose to client) ──
# CARVERTICAL_API_KEY=your_carvertical_api_key
# AUTODNA_API_KEY=your_autodna_api_key
# EPICVIN_API_KEY=your_epicvin_api_key

# ═══════════════════════════════════════════
# VERCEL ENVIRONMENT VARIABLES
# Set these in Vercel Dashboard → Settings → Environment Variables
# Only EXPO_PUBLIC_* variables are needed for the web build
# ═══════════════════════════════════════════
