# ═══════════════════════════════════════════
# VoltCheck — .gitignore
# SECURITY: Prevents API keys, Firebase config,
# and sensitive data from entering the repository
# ═══════════════════════════════════════════

# ── Dependencies ──
node_modules/
functions/node_modules/
functions/lib/

# ── Expo ──
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native Builds ──
/ios/
/android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ── Metro ──
.metro-health-check*

# ── Debug ──
npm-debug.*
yarn-debug.*
yarn-error.*

# ════════════════════════════════════
# 🔒 SECURITY — SENSITIVE FILES
# ════════════════════════════════════

# Environment variables (ALL variants)
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
!.env.example

# Firebase service account keys
*-firebase-adminsdk-*.json
service-account*.json
serviceAccountKey*.json
firebase-adminsdk*.json

# Firebase emulator data
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
.firebase/
.firebaserc

# Google Cloud credentials
gcloud-*.json
application_default_credentials.json

# Stripe keys file
stripe-keys.json

# ── IDE & OS ──
.DS_Store
*.pem
Thumbs.db
.vscode/settings.json
.idea/

# ── TypeScript ──
*.tsbuildinfo

# ── Vercel ──
.vercel/

# ── Test & Coverage ──
coverage/
.nyc_output/
jest-results/
